# EditorConfig: https://EditorConfig.org
root = true

# 모든 파일
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# 코드 파일
[*.{js,jsx,ts,tsx,mjs,cjs}]
indent_style = space
indent_size = 2

# JSON 파일
[*.json]
indent_style = space
indent_size = 2

# YAML 파일
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Markdown 파일
[*.md]
trim_trailing_whitespace = false

# Package.json
[package.json]
indent_style = space
indent_size = 2
